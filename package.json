{
  "name": "claude-settings-manager",
  "displayName": "Claude Settings Manager",
  "description": "One sidebar to browse and edit all your Claude Code settings — global ~/.claude config, MCP servers, current project, and every git repo's CLAUDE.md / AGENTS.md / .claude/ files.",
  "version": "0.2.1",
  "publisher": "broker4develop",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0",
    "node": ">=18"
  },
  "categories": ["Other", "Extension Packs"],
  "keywords": [
    "claude",
    "claude-code",
    "claude.md",
    "agents.md",
    "mcp",
    "model-context-protocol",
    "anthropic",
    "settings",
    "sidebar",
    "project-manager",
    "repo-finder"
  ],
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/broker4develop-2/vscode-claude-finder"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onView:claudeSettings.global",
    "onView:claudeSettings.mcp",
    "onView:claudeSettings.project",
    "onView:claudeSettings.repos"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claudeSettings",
          "title": "Claude Settings",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "claudeSettings": [
        { "id": "claudeSettings.global", "name": "Global" },
        { "id": "claudeSettings.repos", "name": "Repo" },
        { "id": "claudeSettings.mcp", "name": "MCP Servers" },
        { "id": "claudeSettings.project", "name": "Project" }
      ]
    },
    "commands": [
      { "command": "claudeSettings.refresh", "title": "Claude: Refresh", "icon": "$(refresh)" },
      { "command": "claudeSettings.openFile", "title": "Claude: Open File" },
      { "command": "claudeSettings.createIfMissing", "title": "Claude: Create If Missing" },
      { "command": "claudeSettings.revealInFinder", "title": "Claude: Reveal in Finder" },
      { "command": "claudeSettings.addScanRoot", "title": "Claude: Add Scan Root", "icon": "$(add)" },
      { "command": "claudeSettings.removeScanRoot", "title": "Claude: Remove Scan Root" },
      { "command": "claudeSettings.openRepoFolder", "title": "Claude: Open Repo in New Window", "icon": "$(window)" },
      { "command": "claudeSettings.revealItem", "title": "Reveal in Finder" },
      { "command": "claudeSettings.copyPath", "title": "Copy Path" },
      { "command": "claudeSettings.copyRelativePath", "title": "Copy Relative Path" },
      { "command": "claudeSettings.openInTerminal", "title": "Open in Integrated Terminal" },
      { "command": "claudeSettings.deleteItem", "title": "Delete" },
      { "command": "claudeSettings.renameItem", "title": "Rename" }
    ],
    "menus": {
      "view/title": [
        { "command": "claudeSettings.refresh", "when": "view == claudeSettings.global", "group": "navigation" },
        { "command": "claudeSettings.refresh", "when": "view == claudeSettings.mcp", "group": "navigation" },
        { "command": "claudeSettings.refresh", "when": "view == claudeSettings.project", "group": "navigation" },
        { "command": "claudeSettings.addScanRoot", "when": "view == claudeSettings.repos", "group": "navigation@1" },
        { "command": "claudeSettings.refresh", "when": "view == claudeSettings.repos", "group": "navigation@2" }
      ],
      "view/item/context": [
        { "command": "claudeSettings.openRepoFolder", "when": "view == claudeSettings.repos && viewItem == repo", "group": "inline" },
        { "command": "claudeSettings.openRepoFolder", "when": "viewItem == repo", "group": "navigation@1" },
        { "command": "claudeSettings.revealItem", "when": "viewItem == file || viewItem == dir || viewItem == repo", "group": "navigation@2" },
        { "command": "claudeSettings.openInTerminal", "when": "viewItem == dir || viewItem == repo", "group": "navigation@3" },
        { "command": "claudeSettings.copyPath", "when": "viewItem == file || viewItem == dir || viewItem == repo", "group": "5_cutcopypaste@1" },
        { "command": "claudeSettings.copyRelativePath", "when": "viewItem == file || viewItem == dir || viewItem == repo", "group": "5_cutcopypaste@2" },
        { "command": "claudeSettings.renameItem", "when": "viewItem == file || viewItem == dir", "group": "7_modification@1" },
        { "command": "claudeSettings.deleteItem", "when": "viewItem == file || viewItem == dir", "group": "7_modification@2" }
      ]
    },
    "configuration": {
      "title": "Claude Settings Manager",
      "properties": {
        "claudeSettings.scanRoots": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Extra folders to scan for git repositories. Combined with auto-detected common dev folders (workspace, projects, code, dev, src, repos, work, Documents/GitHub, etc.) under your home directory."
        },
        "claudeSettings.autoDetectScanRoots": {
          "type": "boolean",
          "default": true,
          "description": "Auto-detect common dev folders (workspace, projects, code, dev, src, repos, work, Documents/GitHub, …) under your home directory in addition to scanRoots."
        },
        "claudeSettings.scanDepth": {
          "type": "number",
          "default": 3,
          "description": "Maximum depth to search for .git folders inside scan roots."
        },
        "claudeSettings.showOnlyReposWithClaudeConfig": {
          "type": "boolean",
          "default": false,
          "description": "If true, only list repos that already have a CLAUDE.md, AGENTS.md, or .claude/ folder."
        }
      }
    },
    "jsonValidation": [
      {
        "fileMatch": "**/.claude/settings*.json",
        "url": "https://json.schemastore.org/base.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js --production",
    "watch": "node esbuild.js --watch",
    "lint": "eslint src --ext ts",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.24.0",
    "esbuild": "^0.20.0",
    "eslint": "^8.57.0",
    "typescript": "^5.4.0"
  }
}
